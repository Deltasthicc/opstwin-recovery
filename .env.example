# Copy to .env and fill in.

# LLM endpoint (HF router is the default; you can point this at any OpenAI-compatible endpoint)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen3-1.7B-Instruct

# API key (required)
HF_TOKEN=hf_your_token_here

# Optional: if set, inference.py uses EnvClient.from_docker_image(IMAGE_NAME)
# instead of connecting to a local uvicorn server. Leave blank during fast
# iteration on-site.
# IMAGE_NAME=opstwin-recovery

# Optional: override local server URL (defaults to http://localhost:8000)
# LOCAL_URL=http://localhost:8000

# Optional: TRL reports metrics to Trackio if this is set
# TRACKIO_API_KEY=your_trackio_key
