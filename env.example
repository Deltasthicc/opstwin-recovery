# Copy this to .env and fill in. Never commit .env to git (add to .gitignore).

# LLM endpoint (HF router is the default; any OpenAI-compatible endpoint works)
API_BASE_URL=https://router.huggingface.co/v1
# Primary model. inference.py falls back to Qwen3-8B / Qwen2.5-7B-Instruct /
# Llama-3.1-8B-Instruct if this one isn't served by the router.
MODEL_NAME=Qwen/Qwen3-8B

# API key (required). A fine-grained "read" + "Make calls to Inference
# Providers" token is sufficient. Get one at:
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Connection mode for inference.py:
#   - If IMAGE_NAME is set, launches the Docker image (submission mode).
#   - If blank, connects to local uvicorn at LOCAL_URL (fast iteration).
# Leave blank AND start `python -m server.app` in another window, OR
# set IMAGE_NAME and let inference.py manage the container itself.
# IMAGE_NAME=opstwin-recovery

# Optional: override local server URL (defaults to http://localhost:8000)
# LOCAL_URL=http://localhost:8000

# Optional: TRL reports metrics to Trackio if this is set
# TRACKIO_API_KEY=your_trackio_key
